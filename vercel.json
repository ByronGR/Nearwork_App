{
  "rewrites": [
    {
      "source": "/admin-dashboard/:path*",
      "destination": "/admin-dashboard.html"
    },
    {
      "source": "/apply/:path*",
      "destination": "/admin-dashboard.html"
    }
  ],
  "headers": [
    {
      "source": "/admin-dashboard.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
